# ============================================================================
# WinBuild — артефакти збірки та великі бінарники
# ============================================================================

# Вихідні офіційні ISO Microsoft (~6 ГБ кожен)
Origin/
*.iso

# Готові кастомні ISO
Modified/

# Тимчасова папка збірки
Work/

# Журнали збірки
Logs/
*.log

# ============================================================================
# Assets — інсталятори, драйвери, оновлення
# ----------------------------------------------------------------------------
# У репо лишається тільки SetupComplete.cmd та структура папок (через .gitkeep).
# Сам вміст Apps/, Drivers/, Updates/ виключений, бо:
#   - інсталятори великі (Office, 1С тощо)
#   - мають власні ліцензії правовласників
#   - драйвери та .msu — теж великі бінарники
# ============================================================================
Assets/Apps/
Assets/Drivers/
Assets/Updates/

# Залишити в Assets/ тільки SetupComplete.cmd
!Assets/SetupComplete.cmd

# ============================================================================
# Інсталятори та архіви
# ============================================================================
*.msi
*.msu
*.cab
*.exe
*.zip
*.7z
*.rar

# WIM / ESD
*.wim
*.esd

# ============================================================================
# Тимчасові файли Windows / PowerShell
# ============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
*.lnk
~$*
*.tmp
*.bak

# PowerShell профілі / історія
*.ps1xml
PowerShell_transcript.*.txt

# ============================================================================
# Редактори та IDE
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# OS-специфічне
# ============================================================================
.DS_Store
$RECYCLE.BIN/
System Volume Information/
